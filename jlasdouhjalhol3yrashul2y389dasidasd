-- Separate ScreenGui so notifs keep showing while the window is hidden.
local function getNotifyGui()
	if Vertex._notifyGui and Vertex._notifyGui.Parent then
		return Vertex._notifyGui
	end
	local gui = create("ScreenGui", {
		Name = "VertexNotifications",
		ResetOnSpawn = false,
		IgnoreGuiInset = true,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		DisplayOrder = 120,
	}, getGuiParent())
	if syn and type(syn.protect_gui) == "function" then
		pcall(syn.protect_gui, gui)
	end
	Vertex._notifyGui = gui
	return gui
end

function Vertex:Notify(options)
	if type(options) == "string" then
		options = { Title = options }
	end
	options = options or {}

	if #self.Windows == 0 then
		warn("[Vertex UI] Create a window before sending notifications.")
		return
	end

	local screenGui = getNotifyGui()
	local holder = screenGui:FindFirstChild("Notifications")
	if not holder then
		holder = create("Frame", {
			Name = "Notifications",
			AnchorPoint = Vector2.new(1, 0),
			Position = UDim2.new(1, -18, 0, 18),
			Size = UDim2.fromOffset(320, 0),
			AutomaticSize = Enum.AutomaticSize.Y,
			BackgroundTransparency = 1,
			ZIndex = 60,
		}, screenGui)
		create("UIListLayout", {
			Padding = UDim.new(0, 8),
			HorizontalAlignment = Enum.HorizontalAlignment.Right,
			SortOrder = Enum.SortOrder.LayoutOrder,
		}, holder)
	end

	local notification = create("Frame", {
		BackgroundColor3 = self.Theme.Surface,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(310, options.Description and 74 or 54),
		Position = UDim2.fromOffset(88, 0),
		ZIndex = 61,
	}, holder)
	addCorner(notification, RADIUS.Card)
	local notifShadow = addDropShadow(notification, {
		Blur = 48,
		YOffset = 10,
		Spread = 14,
		Transparency = 0.16,
	})
	local notifShadowRest = 0.16
	local notifScale = create("UIScale", { Scale = 0.86 }, notification)

	local function setNotifShadowAlpha(alpha, animate, speed)
		if not notifShadow then
			return
		end
		if notifShadow.ClassName == "UIShadow" then
			if animate then
				motion(notifShadow, "Transparency", alpha, speed)
			else
				setNow(notifShadow, "Transparency", alpha)
			end
		elseif notifShadow:IsA("ImageLabel") then
			if animate then
				motion(notifShadow, "ImageTransparency", alpha, speed)
			else
				setNow(notifShadow, "ImageTransparency", alpha)
			end
		end
	end

	local accentColor = self.Theme.Accent
	local accentBar = create("Frame", {
		BackgroundColor3 = accentColor,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(0, 0.5),
		Position = UDim2.new(0, 12, 0.5, 0),
		Size = UDim2.new(0, 3, 0, 0),
		ZIndex = 62,
	}, notification)
	addCorner(accentBar, RADIUS.Pill)

	local title = create(
		"TextLabel",
		merge(textProps(TEXT.Label, self.Theme.Text, self.Fonts.Bold), {
			Text = options.Title or "Notification",
			TextTransparency = 1,
			Position = UDim2.fromOffset(28, options.Description and 11 or 0),
			Size = UDim2.new(1, -40, options.Description and 0 or 1, options.Description and 20 or 0),
			ZIndex = 62,
		}),
		notification
	)

	local body
	if options.Description then
		body = create(
			"TextLabel",
			merge(textProps(TEXT.Small, self.Theme.TextMuted, self.Fonts.Medium), {
				Text = options.Description,
				TextTransparency = 1,
				Position = UDim2.fromOffset(28, 34),
				Size = UDim2.new(1, -40, 0, 30),
				TextWrapped = true,
				TextYAlignment = Enum.TextYAlignment.Top,
				ZIndex = 62,
			}),
			notification
		)
	end

	local duration = math.max(tonumber(options.Duration) or 3, 0.6)

	-- Enter: slide + scale spring + staggered fade + accent grow.
	setNotifShadowAlpha(1, false)
	motion(notification, "BackgroundTransparency", 0, 14)
	motion(notification, "Position", UDim2.fromOffset(-6, 0), 15)
	motion(notifScale, "Scale", 1.045, 16)
	setNotifShadowAlpha(notifShadowRest, true, 14)
	motion(accentBar, "BackgroundTransparency", 0, 14)
	motion(accentBar, "Size", UDim2.new(0, 3, 1, -24), 18)
	motion(title, "TextTransparency", 0, 14)
	if body then
		task.delay(0.05, function()
			if body.Parent then
				motion(body, "TextTransparency", 0, 14)
			end
		end)
	end
	task.delay(0.12, function()
		if not notification.Parent then
			return
		end
		motion(notification, "Position", UDim2.fromOffset(0, 0), 13)
		motion(notifScale, "Scale", 1, 12)
	end)

	task.delay(duration, function()
		if not notification.Parent then
			return
		end
		-- Exit: shrink, slide right, fade.
		motion(accentBar, "BackgroundTransparency", 1, 22)
		motion(accentBar, "Size", UDim2.new(0, 3, 0, 0), 20)
		motion(title, "TextTransparency", 1, 22)
		if body then
			motion(body, "TextTransparency", 1, 22)
		end
		setNotifShadowAlpha(1, true, 22)
		motion(notification, "BackgroundTransparency", 1, 22)
		motion(notification, "Position", UDim2.fromOffset(96, 0), 18)
		motion(notifScale, "Scale", 0.9, 18)
		task.wait(0.32)
		if notification.Parent then
			notification:Destroy()
		end
	end)

	return notification
end

-- Nexonix-style alias: Notification(name, duration)
function Vertex:Notification(name, duration, _color)
	if type(name) == "table" then
		return self:Notify(name)
	end
	return self:Notify({ Title = name, Duration = duration })
end

