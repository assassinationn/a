	-- Animated unload: fade + slide the window out, then destroy everything.
	function window:Close()
		if self._closing then
			return
		end
		self._closing = true
		setReopenChipVisible(false)

		local rest = main.Position
		setNow(main, "Position", rest)
		motion(uiScale, "Scale", 0.9, 18)
		motion(main, "Position", rest + UDim2.fromOffset(0, 24), 18)
		fadeOutTree(main, 20)

		-- Fade floating chrome (watermark + keybind list + live notifications) with the window.
		for _, watermark in ipairs(Vertex.Watermarks) do
			if watermark.Instance and watermark.Instance.Parent then
				local mark = watermark.Instance
				local markScale = mark:FindFirstChildOfClass("UIScale")
				if not markScale then
					markScale = create("UIScale", { Scale = 1 }, mark)
				end
				motion(markScale, "Scale", 0.94, 18)
				motion(mark, "Position", mark.Position + UDim2.fromOffset(0, -10), 18)
				fadeOutTree(mark, 20)
				if watermark._conn then
					watermark._conn:Disconnect()
					watermark._conn = nil
				end
			end
		end

		for _, keyList in ipairs(Vertex.KeybindLists) do
			if keyList and keyList.FadeOut then
				keyList:FadeOut(18)
			elseif keyList and keyList.Instance and keyList.Instance.Parent then
				fadeOutTree(keyList.Instance, 18)
			end
		end

		if Vertex._notifyGui and Vertex._notifyGui.Parent then
			local holder = Vertex._notifyGui:FindFirstChild("Notifications")
			if holder then
				for _, notif in ipairs(holder:GetChildren()) do
					if notif:IsA("GuiObject") then
						local notifScale = notif:FindFirstChildOfClass("UIScale")
						fadeOutTree(notif, 20)
						motion(notif, "Position", UDim2.fromOffset(56, 0), 18)
						if notifScale then
							motion(notifScale, "Scale", 0.92, 18)
						end
					end
				end
			end
		end

		task.delay(0.34, function()
			self:Destroy()
		end)
	end

	function window:Destroy()
		clearTooltips()
		for index, item in ipairs(Vertex.Windows) do
			if item == self then
				table.remove(Vertex.Windows, index)
				break
			end
		end
		-- X / Close unloads floating widgets too (watermark + notifications).
		for _, watermark in ipairs(Vertex.Watermarks) do
			if watermark._conn then
				watermark._conn:Disconnect()
				watermark._conn = nil
			end
			if watermark.Instance then
				watermark.Instance:Destroy()
			end
		end
		table.clear(Vertex.Watermarks)
		if Vertex._watermarkGui then
			Vertex._watermarkGui:Destroy()
			Vertex._watermarkGui = nil
		end
		table.clear(Vertex.KeybindLists)
		Vertex.KeyList = nil
		if Vertex._keybindListGui then
			Vertex._keybindListGui:Destroy()
			Vertex._keybindListGui = nil
		end
		if Vertex._notifyGui then
			Vertex._notifyGui:Destroy()
			Vertex._notifyGui = nil
		end
		if reopenGui then
			reopenGui:Destroy()
		end
		screenGui:Destroy()
	end

