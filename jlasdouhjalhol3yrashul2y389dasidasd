function Vertex:KeybindList(params)
	params = params or {}
	if type(params) == "string" then
		params = { Name = params }
	end

	local titleText = tostring(params.Name or params.Title or "Keybinds")
	local host = getKeybindListGui()

	local listWidth = tonumber(params.Width) or 210
	local panelRestTransparency = 0.06

	-- Plain Frame (not CanvasGroup): CanvasGroup rasterizes and makes text blurry +
	-- shows a square silhouette behind UICorner.
	local frame = create("Frame", {
		Name = "VertexKeybindList",
		BackgroundColor3 = self.Theme.Surface,
		BackgroundTransparency = panelRestTransparency,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(listWidth, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		AnchorPoint = params.AnchorPoint or Vector2.new(0, 0.5),
		Position = params.Position or UDim2.new(0, 18, 0.5, 0),
		Active = true,
		Visible = false,
		ZIndex = 80,
	}, host)
	addCorner(frame, RADIUS.Control)
	-- UIShadow only (no ImageLabel fallback sibling — that square peeks past UICorner).
	do
		local ok = pcall(function()
			local s = Instance.new("UIShadow")
			s.Name = "DropShadow"
			s.Color = Color3.fromRGB(0, 0, 0)
			s.Transparency = 0.14
			s.BlurRadius = UDim.new(0, 52)
			s.Offset = UDim2.fromOffset(0, 12)
			s.Spread = UDim2.fromOffset(14, 14)
			s.ZIndex = -1
			s.Parent = frame
			return s
		end)
		if not ok then
			-- ignore
		end
	end
	addPadding(frame, 12, 14, 12, 14)
	makeDraggable(frame, frame)

	create("UIListLayout", {
		FillDirection = Enum.FillDirection.Vertical,
		Padding = UDim.new(0, 8),
		SortOrder = Enum.SortOrder.LayoutOrder,
	}, frame)

	local title = create(
		"TextLabel",
		merge(textProps(TEXT.Label, self.Theme.Text, self.Fonts.SemiBold), {
			Name = "Title",
			Text = titleText,
			Size = UDim2.new(1, 0, 0, 18),
			TextXAlignment = Enum.TextXAlignment.Left,
			RichText = false,
			TextTransparency = 0,
			LayoutOrder = 1,
			ZIndex = 81,
		}),
		frame
	)

	local divider = create("Frame", {
		Name = "Divider",
		BackgroundColor3 = STROKE_COLOR,
		BackgroundTransparency = 0.92,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 1),
		LayoutOrder = 2,
		ZIndex = 81,
	}, frame)

	local content = create("Frame", {
		Name = "Content",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		LayoutOrder = 3,
		ZIndex = 81,
	}, frame)
	create("UIListLayout", {
		FillDirection = Enum.FillDirection.Vertical,
		Padding = UDim.new(0, 8),
		SortOrder = Enum.SortOrder.LayoutOrder,
	}, content)

	local list = {
		Instance = frame,
		Panel = frame,
		Title = title,
		Content = content,
		Binds = {},
		Disabled = false,
		_userHidden = false,
		_toggleableVisible = 0, -- kept for compatibility
		_visibleCount = 0,
		_shown = false,
		_visGen = 0,
		Window = params.Window,
	}

	local uiScale = create("UIScale", { Scale = 1 }, frame)

	local function shouldShow()
		-- Any visible bind (toggleable On/Off or press key) keeps the panel up.
		return not list.Disabled and not list._userHidden and (list._visibleCount or 0) > 0
	end

	-- Fade only the panel chrome + scale — never TextTransparency (keeps glyphs crisp).
	local function setVisibleAnimated(want)
		want = want == true
		list._visGen += 1
		local gen = list._visGen

		if want then
			list._shown = true
			frame.Visible = true
			title.TextTransparency = 0
			setNow(frame, "BackgroundTransparency", 1)
			setNow(uiScale, "Scale", 0.96)
			motion(frame, "BackgroundTransparency", panelRestTransparency, 14)
			motion(uiScale, "Scale", 1, 14)
			task.delay(0.32, function()
				if gen ~= list._visGen or not frame.Parent then
					return
				end
				setNow(frame, "BackgroundTransparency", panelRestTransparency)
				setNow(uiScale, "Scale", 1)
				title.TextTransparency = 0
			end)
		else
			list._shown = false
			if not frame.Visible then
				return
			end
			motion(frame, "BackgroundTransparency", 1, 18)
			motion(uiScale, "Scale", 0.96, 18)
			task.delay(0.28, function()
				if gen ~= list._visGen or not frame.Parent then
					return
				end
				if shouldShow() then
					return
				end
				frame.Visible = false
				setNow(frame, "BackgroundTransparency", panelRestTransparency)
				setNow(uiScale, "Scale", 1)
				title.TextTransparency = 0
			end)
		end
	end

	local function refreshVisibility()
		setVisibleAnimated(shouldShow())
	end

	function list:RefreshVisibility()
		refreshVisibility()
	end

	function list:SetText(text)
		title.Text = tostring(text)
	end

	function list:SetVisibility(visible)
		self._userHidden = not (visible == true)
		refreshVisibility()
	end

	function list:SetEnabled(enabled)
		self.Disabled = not (enabled == true)
		refreshVisibility()
	end

	-- Instantly force a fade-out (used by window Close / Unload).
	function list:FadeOut(speed)
		self._visGen += 1
		local gen = self._visGen
		self._shown = false
		if not frame.Visible then
			return
		end
		motion(frame, "BackgroundTransparency", 1, speed or 18)
		motion(uiScale, "Scale", 0.96, speed or 18)
		task.delay(0.28, function()
			if gen ~= self._visGen or not frame.Parent then
				return
			end
			frame.Visible = false
			setNow(frame, "BackgroundTransparency", panelRestTransparency)
			setNow(uiScale, "Scale", 1)
		end)
	end

	function list:RemoveBind(flag)
		local bindFlag = tostring(flag or "")
		local existing = self.Binds[bindFlag]
		if not existing then
			return false
		end
		existing:Destroy()
		return true
	end

	function list:Register(data)
		data = data or {}
		local bindFlag = tostring(data.Flag or data.Name or HttpService:GenerateGUID(false))
		local bindName = tostring(data.Name or bindFlag)
		local toggleable = data.Toggleable == true
		local keyName = tostring(data.Key or "Unknown")
		local active = data.Active == true
		local bindVisible = data.Visible ~= false

		if self.Binds[bindFlag] then
			self:RemoveBind(bindFlag)
		end

		local row = create("Frame", {
			Name = bindFlag,
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, bindVisible and 18 or 0),
			Visible = bindVisible,
			ZIndex = 82,
		}, content)

		local nameLabel = create(
			"TextLabel",
			merge(textProps(TEXT.Small, Vertex.Theme.TextMuted, Vertex.Fonts.Medium), {
				Name = "Name",
				Text = bindName,
				AnchorPoint = Vector2.new(0, 0.5),
				Position = UDim2.new(0, 0, 0.5, 0),
				Size = UDim2.new(1, -56, 0, 18),
				TextXAlignment = Enum.TextXAlignment.Left,
				TextTruncate = Enum.TextTruncate.AtEnd,
				RichText = false,
				TextTransparency = 0,
				ZIndex = 83,
			}),
			row
		)

		local statusLabel = create(
			"TextLabel",
			merge(textProps(TEXT.Small, Vertex.Theme.TextDim, Vertex.Fonts.SemiBold), {
				Name = "Status",
				Text = toggleable and (active and "On" or "Off") or keyName,
				AnchorPoint = Vector2.new(1, 0.5),
				Position = UDim2.new(1, 0, 0.5, 0),
				AutomaticSize = Enum.AutomaticSize.XY,
				TextXAlignment = Enum.TextXAlignment.Right,
				RichText = false,
				TextTransparency = 0,
				ZIndex = 83,
			}),
			row
		)

		local entry = {
			Flag = bindFlag,
			Toggleable = toggleable,
			Instance = row,
			NameLabel = nameLabel,
			StatusLabel = statusLabel,
			_visible = bindVisible,
			_active = active,
			_key = keyName,
			_pulseToken = 0,
		}

		local function applyToggleableStyle(isOn)
			if isOn then
				nameLabel.TextColor3 = Vertex.Theme.Text
				statusLabel.Text = "On"
				statusLabel.TextColor3 = Vertex.Theme.AccentText
			else
				nameLabel.TextColor3 = Vertex.Theme.TextMuted
				statusLabel.Text = "Off"
				statusLabel.TextColor3 = Vertex.Theme.TextDim
			end
		end

		local function applyPressIdleStyle()
			nameLabel.TextColor3 = Vertex.Theme.TextMuted
			statusLabel.Text = entry._key
			statusLabel.TextColor3 = Vertex.Theme.TextDim
		end

		if toggleable then
			applyToggleableStyle(active)
		else
			applyPressIdleStyle()
		end

		function entry:SetActive(isOn)
			if not self.Toggleable then
				return
			end
			self._active = isOn == true
			applyToggleableStyle(self._active)
		end

		function entry:SetKey(key)
			self._key = tostring(key or "Unknown")
			if not self.Toggleable then
				statusLabel.Text = self._key
			end
		end

		function entry:SetMode(_mode)
			-- Status for toggleable binds is On/Off; mode lives on the control.
		end

		function entry:Set(name)
			nameLabel.Text = tostring(name)
		end

		function entry:Pulse()
			if self.Toggleable then
				return
			end
			self._pulseToken += 1
			local token = self._pulseToken
			setNow(statusLabel, "TextColor3", Vertex.Theme.Text)
			nameLabel.TextColor3 = Vertex.Theme.Text
			motion(statusLabel, "TextColor3", Vertex.Theme.TextDim, 3.2)
			motion(nameLabel, "TextColor3", Vertex.Theme.TextMuted, 3.2)
			task.delay(1.35, function()
				if token ~= self._pulseToken or not statusLabel.Parent then
					return
				end
				applyPressIdleStyle()
			end)
		end

		function entry:SetVisibility(visible)
			visible = visible == true
			local wasVisible = self._visible == true
			self._visible = visible
			row.Visible = visible
			row.Size = UDim2.new(1, 0, 0, visible and 18 or 0)

			if visible and not wasVisible then
				list._visibleCount += 1
				if self.Toggleable then
					list._toggleableVisible += 1
				end
			elseif not visible and wasVisible then
				list._visibleCount = math.max(0, list._visibleCount - 1)
				if self.Toggleable then
					list._toggleableVisible = math.max(0, list._toggleableVisible - 1)
				end
			end
			refreshVisibility()
		end

		function entry:Destroy()
			if self._visible then
				list._visibleCount = math.max(0, list._visibleCount - 1)
				if self.Toggleable then
					list._toggleableVisible = math.max(0, list._toggleableVisible - 1)
				end
			end
			if list.Binds[bindFlag] == entry then
				list.Binds[bindFlag] = nil
			end
			if row.Parent then
				row:Destroy()
			end
			refreshVisibility()
		end

		if bindVisible then
			self._visibleCount += 1
			if toggleable then
				self._toggleableVisible += 1
			end
		end

		self.Binds[bindFlag] = entry
		refreshVisibility()
		watchTheme(function()
			if not row.Parent then
				return false
			end
			if entry.Toggleable then
				applyToggleableStyle(entry._active)
			else
				applyPressIdleStyle()
			end
		end)
		return entry
	end

	function list:AddBind(flag, name, mode, toggled)
		return self:Register({
			Flag = flag,
			Name = name or flag,
			Mode = mode,
			Toggleable = true,
			Active = toggled == true,
		})
	end

	function list:Add(name)
		return self:AddBind(name, name)
	end

	function list:Destroy()
		self._visGen += 1
		local gen = self._visGen
		self.Disabled = true
		self._shown = false

		local function cleanup()
			for flag, entry in pairs(self.Binds) do
				if entry and entry.Instance and entry.Instance.Parent then
					pcall(function()
						entry.Instance:Destroy()
					end)
				end
				self.Binds[flag] = nil
			end
			if frame.Parent then
				frame:Destroy()
			end
			for index, item in ipairs(Vertex.KeybindLists) do
				if item == self then
					table.remove(Vertex.KeybindLists, index)
					break
				end
			end
			if Vertex.KeyList == self then
				Vertex.KeyList = Vertex.KeybindLists[#Vertex.KeybindLists]
			end
		end

		if frame.Visible and frame.Parent then
			motion(frame, "BackgroundTransparency", 1, 18)
			motion(uiScale, "Scale", 0.96, 18)
			task.delay(0.28, function()
				if gen ~= self._visGen then
					return
				end
				cleanup()
			end)
		else
			cleanup()
		end
	end

	watchTheme(function()
		if not frame.Parent then
			return false
		end
		motion(frame, "BackgroundColor3", Vertex.Theme.Surface, 18)
		title.TextColor3 = Vertex.Theme.Text
	end)

	table.insert(self.KeybindLists, list)
	self.KeyList = list
	refreshVisibility()
	return list
end

