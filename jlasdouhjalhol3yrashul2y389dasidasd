-- Register a callback that re-applies theme colours. Return false to drop it.
local function watchTheme(fn)
	table.insert(Vertex.ThemeListeners, fn)
end

local function applyTheme()
	local alive = {}
	for _, fn in ipairs(Vertex.ThemeListeners) do
		local ok, keep = pcall(fn)
		if ok and keep ~= false then
			alive[#alive + 1] = fn
		end
	end
	Vertex.ThemeListeners = alive
end

function Vertex:SetTheme(overrides)
	overrides = overrides or {}
	for key, value in pairs(overrides) do
		if self.Theme[key] ~= nil and typeof(value) == "Color3" then
			self.Theme[key] = value
		end
	end
	if typeof(overrides.Accent) == "Color3" then
		if typeof(overrides.AccentHover) ~= "Color3" then
			self.Theme.AccentHover = overrides.Accent:Lerp(Color3.new(1, 1, 1), 0.18)
		end
		if typeof(overrides.AccentText) ~= "Color3" then
			self.Theme.AccentText = overrides.Accent:Lerp(Color3.new(1, 1, 1), 0.35)
		end
	end
	applyTheme()
end

