	local settingsBtn = create("TextButton", {
		Name = "KeybindSettings",
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(1, -rightOffset, 0.5, 0),
		Size = UDim2.fromOffset(28, 28),
		BackgroundColor3 = Vertex.Theme.SurfaceRaised,
		BorderSizePixel = 0,
		Text = "",
		AutoButtonColor = false,
		Active = true,
		ZIndex = 8,
	}, parent)
	addCorner(settingsBtn, RADIUS.Inner)
	-- Prefer Lucide "settings"; fall back to "sliders-horizontal" then a plain glyph.
	local gear = makeGlyph(settingsBtn, "settings", "⚙", 15, Vertex.Theme.TextMuted)
	if gear:IsA("TextLabel") then
		gear:Destroy()
		gear = makeGlyph(settingsBtn, "sliders-horizontal", "☰", 15, Vertex.Theme.TextMuted)
	end
	gear.AnchorPoint = Vector2.new(0.5, 0.5)
	gear.Position = UDim2.fromScale(0.5, 0.5)
	if gear:IsA("ImageLabel") then
		gear.ScaleType = Enum.ScaleType.Fit
		gear.ImageTransparency = 0
	end

	local function screenGuiOf(instance)
		local current = instance
		while current do
			if current:IsA("ScreenGui") then
				return current
			end
			current = current.Parent
		end
		return getGuiParent()
	end

	-- Parent to ScreenGui so ScrollingFrames don't clip the menu.
	local popover = create("Frame", {
		Name = "ModePopover",
		Visible = false,
		BackgroundColor3 = Vertex.Theme.SurfaceRaised,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(1, 0),
		Size = UDim2.fromOffset(120, 78),
		ZIndex = 120,
	}, screenGuiOf(parent))
	addCorner(popover, RADIUS.Control)
	local popShadow = addDropShadow(popover, {
		Blur = 52,
		YOffset = 12,
		Spread = 16,
		Transparency = 0.16,
	})
	local popShadowRest = 0.16
	addPadding(popover, 6, 6, 6, 6)
	local popScale = create("UIScale", { Scale = 0.92 }, popover)
	create("UIListLayout", {
		Padding = UDim.new(0, 0),
		SortOrder = Enum.SortOrder.LayoutOrder,
	}, popover)

	local function setPopShadowAlpha(alpha, animate, speed)
		if not popShadow then
			return
		end
		if popShadow.ClassName == "UIShadow" then
			if animate then
				motion(popShadow, "Transparency", alpha, speed)
			else
				setNow(popShadow, "Transparency", alpha)
			end
		elseif popShadow:IsA("ImageLabel") then
			if animate then
				motion(popShadow, "ImageTransparency", alpha, speed)
			else
				setNow(popShadow, "ImageTransparency", alpha)
			end
		end
	end

	local modeButtons = {}
	local divider
	local function refreshModes()
		for modeName, button in pairs(modeButtons) do
			local selected = keyControl.Mode == modeName
			button.BackgroundTransparency = 1
			button.FontFace = selected and Vertex.Fonts.Bold or Vertex.Fonts.Medium
			motion(button, "TextColor3", selected and Vertex.Theme.Text or Vertex.Theme.TextMuted, 18)
			motion(button, "TextSize", selected and TEXT.Label or TEXT.Small, 18)
		end
	end

	local function placePopover()
		local gui = screenGuiOf(settingsBtn)
		popover.Parent = gui
		-- Sit to the left of the cursor (AnchorPoint is top-right).
		local mouse = UserInputService:GetMouseLocation()
		local x = math.floor(mouse.X - 6)
		local y = math.floor(mouse.Y + 10)
		popover.Position = UDim2.fromOffset(math.max(8, x), math.max(8, y))
	end

	local isOpen = false
	local function setOpen(wantOpen)
		wantOpen = wantOpen == true
		if wantOpen == isOpen then
			return
		end
		isOpen = wantOpen
		if isOpen then
			refreshModes()
			popover.Visible = true
			placePopover()
			task.defer(placePopover)
			setNow(popScale, "Scale", 0.92)
			setNow(popover, "BackgroundTransparency", 1)
			setPopShadowAlpha(1, false)
			for _, button in pairs(modeButtons) do
				setNow(button, "TextTransparency", 1)
				setNow(button, "BackgroundTransparency", 1)
			end
			if divider then
				setNow(divider, "BackgroundTransparency", 1)
			end
			motion(popScale, "Scale", 1, 16)
			motion(popover, "BackgroundTransparency", 0, 16)
			setPopShadowAlpha(popShadowRest, true, 16)
			for _, button in pairs(modeButtons) do
				motion(button, "TextTransparency", 0, 16)
			end
			if divider then
				motion(divider, "BackgroundTransparency", 0.85, 16)
			end
		else
			motion(popScale, "Scale", 0.92, 20)
			motion(popover, "BackgroundTransparency", 1, 20)
			setPopShadowAlpha(1, true, 20)
			for _, button in pairs(modeButtons) do
				motion(button, "TextTransparency", 1, 20)
			end
			if divider then
				motion(divider, "BackgroundTransparency", 1, 20)
			end
			task.delay(0.18, function()
				if not isOpen and popover.Parent then
					popover.Visible = false
				end
			end)
		end
	end

	local toggleBtn = create(
		"TextButton",
		merge(textProps(TEXT.Small, Vertex.Theme.TextMuted, Vertex.Fonts.Medium), {
			Name = "Toggle",
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 30),
			Text = "Toggle",
			TextXAlignment = Enum.TextXAlignment.Center,
			AutoButtonColor = false,
			ZIndex = 121,
			LayoutOrder = 1,
		}),
		popover
	)
	modeButtons.Toggle = toggleBtn

	divider = create("Frame", {
		Name = "Divider",
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		BackgroundTransparency = 0.85,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 1),
		ZIndex = 121,
		LayoutOrder = 2,
	}, popover)

	local holdBtn = create(
		"TextButton",
		merge(textProps(TEXT.Small, Vertex.Theme.TextMuted, Vertex.Fonts.Medium), {
			Name = "Hold",
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 30),
			Text = "Hold",
			TextXAlignment = Enum.TextXAlignment.Center,
			AutoButtonColor = false,
			ZIndex = 121,
			LayoutOrder = 3,
		}),
		popover
	)
	modeButtons.Hold = holdBtn

	for modeName, button in pairs(modeButtons) do
		connect(button.MouseButton1Click, function()
			keyControl:SetMode(modeName)
			refreshModes()
		end)
	end
	refreshModes()

	connect(settingsBtn.MouseButton1Click, function()
		setOpen(not isOpen)
	end)
	connect(settingsBtn.MouseEnter, function()
		motion(settingsBtn, "BackgroundColor3", Vertex.Theme.SurfaceHover, 20)
		paintGlyph(gear, Vertex.Theme.Text)
	end)
	connect(settingsBtn.MouseLeave, function()
		motion(settingsBtn, "BackgroundColor3", Vertex.Theme.SurfaceRaised, 20)
		paintGlyph(gear, Vertex.Theme.TextMuted)
	end)

	-- Close when clicking elsewhere.
	connect(UserInputService.InputBegan, function(input)
		if not isOpen then
			return
		end
		if
			input.UserInputType ~= Enum.UserInputType.MouseButton1
			and input.UserInputType ~= Enum.UserInputType.Touch
		then
			return
		end
		task.defer(function()
			if not isOpen then
				return
			end
			local pos = input.Position
			local pPos, pSize = popover.AbsolutePosition, popover.AbsoluteSize
			local sPos, sSize = settingsBtn.AbsolutePosition, settingsBtn.AbsoluteSize
			local overPopover = pos.X >= pPos.X
				and pos.X <= pPos.X + pSize.X
				and pos.Y >= pPos.Y
				and pos.Y <= pPos.Y + pSize.Y
			local overBtn = pos.X >= sPos.X
				and pos.X <= sPos.X + sSize.X
				and pos.Y >= sPos.Y
				and pos.Y <= sPos.Y + sSize.Y
			if not overPopover and not overBtn then
				setOpen(false)
			end
		end)
	end)

	connect(settingsBtn.AncestryChanged, function(_, parentNow)
		if not parentNow and popover.Parent then
			popover:Destroy()
		end
	end)

	local oldSetMode = keyControl.SetMode
	function keyControl:SetMode(mode)
		if oldSetMode then
			oldSetMode(self, mode)
		else
			self.Mode = normalizeKeyMode(mode)
		end
		refreshModes()
	end

	return settingsBtn
end

-- One-shot / Toggle / Hold input wiring.
-- Toggleable keybinds show Hold/Toggle settings; one-shot keybinds fire once on press.
local function wireKeybindRuntime(keyControl, options)
	options = options or {}
	local toggleable = options.Toggleable == true
	keyControl.Toggleable = toggleable
	if toggleable then
		keyControl.Mode = normalizeKeyMode(options.Mode or keyControl.Mode or "Toggle")
	else
		keyControl.Mode = "Press"
	end
	keyControl.Active = false

	function keyControl:SetActive(active)
		active = active == true
		if self.Active == active then
			return
		end
		self.Active = active
		if self._listEntry and self._listEntry.SetActive then
			self._listEntry:SetActive(active)
		end
		safeCall(options.OnActive, active)
		if active then
			safeCall(options.Pressed, true)
		end
	end

	connect(UserInputService.InputBegan, function(input, processed)
		if processed or keyControl._listening then
			return
		end
		if input.KeyCode == Enum.KeyCode.Unknown or input.KeyCode ~= keyControl.Value then
			return
		end
		if not keyControl.Toggleable then
			safeCall(options.Pressed, true)
			safeCall(options.OnActive, true)
			if keyControl._listEntry and keyControl._listEntry.Pulse then
				keyControl._listEntry:Pulse()
			end
			return
		end
		if keyControl.Mode == "Hold" then
			keyControl:SetActive(true)
		else
			keyControl:SetActive(not keyControl.Active)
		end
	end)
	connect(UserInputService.InputEnded, function(input)
		if not keyControl.Toggleable or keyControl.Mode ~= "Hold" then
			return
		end
		if input.KeyCode == keyControl.Value then
			keyControl:SetActive(false)
		end
	end)
end

-- Attach a keybind control to the active KeybindList (if any).
local function linkKeybindToList(keyControl, options, fallbackName)
	options = options or {}
	local list = Vertex.KeyList
	if (not list or type(list.Register) ~= "function") and type(getgenv) == "function" then
		local env = getgenv()
		if type(env) == "table" then
			if type(env.Vertex) == "table" and type(env.Vertex.KeyList) == "table" then
				list = env.Vertex.KeyList
			elseif type(env.Library) == "table" and type(env.Library.KeyList) == "table" then
				list = env.Library.KeyList
			end
		end
	end
	if not list or type(list.Register) ~= "function" then
		return
	end

	local name = options.ListName or options.Name or fallbackName or keyControl.Flag or "Keybind"
	local startVisible = options.ListVisible
	if startVisible == nil then
		startVisible = true
	end
	keyControl._listEntry = list:Register({
		Flag = keyControl.Flag,
		Name = name,
		Toggleable = keyControl.Toggleable == true,
		Mode = keyControl.Mode,
		Key = keyControl.Value and keyControl.Value.Name or "Unknown",
		Active = keyControl.Active == true,
		Visible = startVisible == true,
		Control = keyControl,
	})

	local previousSetVisibility = keyControl.SetVisibility
	function keyControl:SetVisibility(visible)
		visible = visible == true
		if previousSetVisibility then
			previousSetVisibility(self, visible)
		elseif self.Instance then
			self.Instance.Visible = visible
		end
		if self._listEntry and self._listEntry.SetVisibility then
			self._listEntry:SetVisibility(visible)
		end
	end

	local previousSet = keyControl.Set
	if type(previousSet) == "function" then
		function keyControl:Set(...)
			previousSet(self, ...)
			if self._listEntry then
				if self._listEntry.SetKey then
					self._listEntry:SetKey(self.Value and self.Value.Name or "Unknown")
				end
				if self.Toggleable and self._listEntry.SetMode then
					self._listEntry:SetMode(self.Mode)
				end
				if self.Toggleable and self._listEntry.SetActive then
					self._listEntry:SetActive(self.Active == true)
				end
			end
		end
	end

	local previousSetMode = keyControl.SetMode
	if type(previousSetMode) == "function" then
		function keyControl:SetMode(...)
			previousSetMode(self, ...)
			if self._listEntry and self._listEntry.SetMode then
				self._listEntry:SetMode(self.Mode)
			end
		end
	end
end

