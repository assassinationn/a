						BorderSizePixel = 0,
						Text = value.Name,
						TextXAlignment = Enum.TextXAlignment.Center,
						AutoButtonColor = false,
						ZIndex = 3,
					}),
					row
				)
				addCorner(bindButton, RADIUS.Inner)
				addStroke(bindButton, FIELD_STROKE, nil, FIELD_STROKE_THICKNESS)

				local control = attachControlApi({
					Instance = row,
					Label = label,
					Flag = flag,
					Value = value,
					Toggleable = toggleable,
					Mode = mode,
					_listening = false,
				}, label)

				function control:Set(newValue, silent)
					local modeFromTable
					if typeof(newValue) == "table" and newValue.Key then
						modeFromTable = newValue.Mode
						newValue = resolveKeyCode(newValue.Key)
					end
					if typeof(newValue) ~= "EnumItem" then
						return
					end
					self.Value = newValue
					if self.Toggleable and modeFromTable then
						self.Mode = normalizeKeyMode(modeFromTable)
					end
					Vertex.Flags[flag] = { Key = newValue.Name, Mode = self.Mode }
					bindButton.Text = newValue.Name
					if not silent then
						safeCall(keybindOptions.Callback, newValue)
					end
				end

				function control:SetMode(modeName)
					if not self.Toggleable then
						return
					end
					self.Mode = normalizeKeyMode(modeName)
					Vertex.Flags[flag] = { Key = self.Value.Name, Mode = self.Mode }
					if self.Active and self.Mode == "Hold" then
						self:SetActive(false)
					end
				end

				if toggleable then
					attachKeybindModeSettings(row, control, 14)
				end
				wireKeybindRuntime(control, keybindOptions)
				linkKeybindToList(control, keybindOptions, keybindOptions.Name or flag)

				connect(bindButton.MouseButton1Click, function()
					control._listening = true
					bindButton.Text = "..."
					bindButton.TextColor3 = Vertex.Theme.AccentText
					motion(bindButton, "BackgroundColor3", Vertex.Theme.SurfaceHover, 20)
				end)
				connect(UserInputService.InputBegan, function(input)
					if control._listening and input.KeyCode ~= Enum.KeyCode.Unknown then
						control._listening = false
						bindButton.TextColor3 = Vertex.Theme.TextMuted
						control:Set(input.KeyCode)
						motion(bindButton, "BackgroundColor3", Vertex.Theme.Background, 20)
					end
				end)
				registerFlag(flag, function(v)
					control:Set(v, false)
				end)
				table.insert(self.Items, control)
				return control
			end

			function section:AddColorPicker(colorOptions)
				colorOptions = colorOptions or {}
				local row = makeControl(self, colorOptions.Description and 56 or SPACING.ControlH)
				local label = inlineLabel(row, colorOptions.Name or "Color", colorOptions.Description)
				attachTooltip(row, colorOptions.Tooltip)
				local control = attachControlApi({ Instance = row, Label = label, _nestOffset = 14 }, label)
				local picker = attachColorPicker(control, colorOptions)
				control.ColorPicker = picker
				control.Set = function(_, ...)
					return picker:Set(...)
				end
				table.insert(self.Items, control)
				return control
			end

			function section:SetVisibility(visible)
				visible = visible == true
				self.Visible = visible
				if self.Instance then
					self.Instance.Visible = visible
				end
			end

			-- Optional initial visibility (default true).
			if sectionOptions.Visible == false then
				section:SetVisibility(false)
			else
				section.Visible = true
			end

			-- Nexonix-style short aliases.
			section.Label = section.AddLabel
			section.Button = section.AddButton
			section.Toggle = section.AddToggle
			section.Slider = section.AddSlider
			section.RangeSlider = section.AddRangeSlider
			section.Dropdown = section.AddDropdown
			section.Textbox = section.AddInput
			section.Input = section.AddInput
			section.Keybind = section.AddKeybind
			section.ColorPicker = section.AddColorPicker

			table.insert(tab.Sections, section)
			return section
		end

		table.insert(window.Tabs, tab)
		if not window.CurrentTab then
			tab:Select()
		end
		return tab
	end

	table.insert(self.Windows, window)

	-- Auto keybind list: hidden until at least one visible toggleable bind exists.
	window.KeybindList = self:KeybindList({
		Name = options.KeybindListName or "Keybinds",
		Window = window,
	})

	return window
end

