		local function makeAction(name, order, bg, textColor)
			local btn = create(
				"TextButton",
				merge(textProps(TEXT.Small, textColor, Vertex.Fonts.Bold), {
					Name = name,
					Text = name,
					BackgroundColor3 = bg,
					BackgroundTransparency = 1,
					TextTransparency = 1,
