--[[
	Vertex UI
	A compact, one-file Roblox UI library.

	- BuilderSans typography (heavy, readable)
	- Near-black surfaces, soft field strokes, Heartbeat lerp smoothing
	- Lucide icons (runtime) + optional window Icon/Logo
	- Nexonix-compatible API aliases (Window/Page/Section/Toggle/...)

	Quick start:
		local Vertex = loadstring(game:HttpGet("YOUR_RAW_URL"))()
		local Window = Vertex:Window({
			Title = "Vertex",
			Icon = "rbxassetid://11028823406",
		})
		local Main = Window:Page({ Name = "Main", Icon = "layout-dashboard" })
		local General = Main:Section({ Name = "General" })

		General:Toggle({
			Name = "Enabled",
			Default = false,
			Callback = function(value) print(value) end,
		})
]]

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")
local CoreGui = game:GetService("CoreGui")
local StatsService = game:GetService("Stats")

local flagData = {}

local Vertex
Vertex = {
	Version = "0.5.1",
	-- Backing store for Flags; assignment triggers debounced autosave.
	_flagData = flagData,
	Flags = setmetatable({}, {
		__index = flagData,
		__newindex = function(_, key, value)
			flagData[key] = value
			if
				Vertex
				and Vertex.ConfigState
				and Vertex.ConfigState.AutoSave
				and Vertex.ConfigState.AutoSaveReady
				and not Vertex.ConfigState.Loading
				and tostring(Vertex.ConfigState.Name or "") ~= ""
				and type(Vertex.QueueConfigSave) == "function"
			then
				Vertex:QueueConfigSave()
			end
		end,
	}),
	SetFlags = {}, -- Flag → setter used by LoadConfig
	Windows = {},
	Connections = {},
	Watermarks = {},
	KeybindLists = {},
	KeyList = nil,
	ActiveTooltips = {},
	ThemeListeners = {},
	MenuKeybind = Enum.KeyCode.RightShift,
	Directory = "nexonix",
	Folders = {
		Configs = "/Configs",
		Assets = "/Assets",
	},
	ConfigState = {
		AutoLoad = false,
		Name = "",
		Delay = 0.25,
		Silent = false,
		AutoSave = false,
		AutoSaveReady = false,
		Loading = false,
		SaveToken = 0,
		SaveDelay = 0.25,
		PendingConfig = nil,
	},
}

