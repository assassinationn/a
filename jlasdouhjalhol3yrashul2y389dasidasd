-- Own ScreenGui so the watermark stays up while the menu is hidden.
local function getWatermarkGui()
	if Vertex._watermarkGui and Vertex._watermarkGui.Parent then
		return Vertex._watermarkGui
	end
	local gui = create("ScreenGui", {
		Name = "VertexWatermarkGui",
		ResetOnSpawn = false,
		IgnoreGuiInset = true,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		DisplayOrder = 110,
	}, getGuiParent())
	if syn and type(syn.protect_gui) == "function" then
		pcall(syn.protect_gui, gui)
	end
	Vertex._watermarkGui = gui
	return gui
end

local function makeWatermarkSeparator(parent, order)
	local wrap = create("Frame", {
		Name = "Sep",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(14, 18),
		ZIndex = 71,
		LayoutOrder = order,
	}, parent)
	create("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromScale(0.5, 0.5),
		Size = UDim2.fromOffset(1, 14),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		BackgroundTransparency = 0.82,
		BorderSizePixel = 0,
		ZIndex = 72,
	}, wrap)
	return wrap
end

function Vertex:Watermark(params)
	params = params or {}
	if type(params) == "string" then
		params = { Name = params }
	end

	local showFps = params.ShowFps ~= false
	local showPing = params.ShowPing ~= false
	local titleText = tostring(params.Text or params.Name or params.Title or "Vertex")
	local iconSource = params.Icon or params.Logo or params.icon or params.logo
	if (not iconSource or iconSource == "") and self.Windows[#self.Windows] then
		-- Fall back to the latest window icon if one exists in the tree.
		local win = self.Windows[#self.Windows]
		local top = win.ScreenGui and win.ScreenGui:FindFirstChild("Window", true)
		local bar = top and top:FindFirstChild("TopBar")
		local icon = bar and bar:FindFirstChild("WindowIcon")
		if icon and icon:IsA("ImageLabel") then
			iconSource = icon.Image
		end
	end

	local frame = create("Frame", {
		Name = "VertexWatermark",
		BackgroundColor3 = self.Theme.Surface,
		BackgroundTransparency = 0.06,
		BorderSizePixel = 0,
		AutomaticSize = Enum.AutomaticSize.XY,
		AnchorPoint = params.AnchorPoint or Vector2.new(1, 0),
		Position = params.Position or UDim2.new(1, -18, 0, 18),
		Active = true,
		ZIndex = 70,
	}, getWatermarkGui())
	addCorner(frame, RADIUS.Control)
	addDropShadow(frame, { Blur = 48, YOffset = 10, Spread = 14, Transparency = 0.16 })
	addPadding(frame, 10, 16, 10, 14)
	create("UIListLayout", {
		FillDirection = Enum.FillDirection.Horizontal,
		VerticalAlignment = Enum.VerticalAlignment.Center,
		Padding = UDim.new(0, 0),
		SortOrder = Enum.SortOrder.LayoutOrder,
	}, frame)
	makeDraggable(frame, frame)

	local layoutOrder = 0
	if iconSource and iconSource ~= "" then
		layoutOrder += 1
		local icon = create("ImageLabel", {
			Name = "Icon",
			BackgroundTransparency = 1,
			Image = tostring(iconSource),
			Size = UDim2.fromOffset(22, 22),
			ScaleType = Enum.ScaleType.Fit,
			ZIndex = 71,
			LayoutOrder = layoutOrder,
		}, frame)
		addCorner(icon, RADIUS.Inner)
		layoutOrder += 1
		create("Frame", {
			BackgroundTransparency = 1,
			Size = UDim2.fromOffset(10, 1),
			LayoutOrder = layoutOrder,
			ZIndex = 71,
		}, frame)
	end

	layoutOrder += 1
	local title = create(
		"TextLabel",
		merge(textProps(TEXT.Label, self.Theme.Text, self.Fonts.SemiBold), {
			Name = "Title",
			Text = titleText,
			AutomaticSize = Enum.AutomaticSize.XY,
			ZIndex = 71,
			LayoutOrder = layoutOrder,
		}),
		frame
	)

	local fpsLabel, pingLabel
	if showFps then
		layoutOrder += 1
		makeWatermarkSeparator(frame, layoutOrder)
		layoutOrder += 1
		fpsLabel = create(
			"TextLabel",
			merge(textProps(TEXT.Label, self.Theme.TextMuted, self.Fonts.Medium), {
				Name = "Fps",
				Text = "— fps",
				AutomaticSize = Enum.AutomaticSize.XY,
				ZIndex = 71,
				LayoutOrder = layoutOrder,
			}),
			frame
		)
	end
	if showPing then
		layoutOrder += 1
		makeWatermarkSeparator(frame, layoutOrder)
		layoutOrder += 1
		pingLabel = create(
			"TextLabel",
			merge(textProps(TEXT.Label, self.Theme.TextMuted, self.Fonts.Medium), {
				Name = "Ping",
				Text = "— ms",
				AutomaticSize = Enum.AutomaticSize.XY,
				ZIndex = 71,
				LayoutOrder = layoutOrder,
			}),
			frame
		)
	end

	local watermark = {
		Instance = frame,
		Title = title,
		FpsLabel = fpsLabel,
		PingLabel = pingLabel,
		_fps = 60,
		_ping = 0,
	}

	function watermark:SetText(text)
		-- Keep title only; fps/ping stay on their own labels.
		local raw = tostring(text or "")
		local head = string.split(raw, "|")[1]
		title.Text = (head and head:gsub("^%s+", ""):gsub("%s+$", "")) or raw
	end
	function watermark:SetTitle(text)
		title.Text = tostring(text)
	end
	function watermark:SetVisibility(visible)
		frame.Visible = visible == true
	end
	function watermark:Destroy()
		if self._conn then
			self._conn:Disconnect()
			self._conn = nil
		end
		for index, item in ipairs(Vertex.Watermarks) do
			if item == self then
				table.remove(Vertex.Watermarks, index)
				break
			end
		end
		if frame.Parent then
			frame:Destroy()
		end
	end

	if showFps or showPing then
		local frameTimer = tick()
		local frameCounter = 0
		local lastPingUpdate = 0
		watermark._conn = RunService.RenderStepped:Connect(function()
			if not frame.Parent then
				if watermark._conn then
					watermark._conn:Disconnect()
					watermark._conn = nil
				end
				return
			end

			frameCounter += 1
			local now = tick()

			if showFps and now - frameTimer >= 1 then
				watermark._fps = frameCounter
				frameTimer = now
				frameCounter = 0
				if fpsLabel and fpsLabel.Parent then
					fpsLabel.Text = string.format("%d fps", watermark._fps)
				end
			end

			if showPing and now - lastPingUpdate >= 1 then
				lastPingUpdate = now
				pcall(function()
					local pingItem = StatsService.Network.ServerStatsItem:FindFirstChild("Data Ping")
					if pingItem then
						watermark._ping = math.floor(pingItem:GetValue())
					end
				end)
				if pingLabel and pingLabel.Parent then
					pingLabel.Text = string.format("%d ms", watermark._ping)
				end
			end
		end)
	end

	table.insert(self.Watermarks, watermark)
	return watermark
end

--=====================================================================
-- Public: config (Nexonix-compatible: nexonix/Configs/<name>.json)
--=====================================================================

function Vertex:GetConfigPath(configName)
	local name = tostring(configName or "")
	if name == "" then
		return nil
	end
	local path = (self.Directory or "nexonix") .. (self.Folders and self.Folders.Configs or "/Configs") .. "/" .. name
	if path:sub(-5) ~= ".json" then
		path = path .. ".json"
	end
	return path
end

function Vertex:GetConfig()
	local payload = {}
	for flag, value in pairs(self._flagData) do
		if typeof(value) == "EnumItem" then
			payload[flag] = { Key = value.Name, Mode = "Toggle" }
		elseif type(value) == "table" and typeof(value.Color) == "Color3" then
			local hex = value.HexValue
			if type(hex) == "string" and hex ~= "" then
				if hex:sub(1, 1) ~= "#" then
					hex = "#" .. hex
				end
			else
				hex = colorToHex(value.Color)
			end
			payload[flag] = { Color = hex, Alpha = value.Alpha or 1 }
		elseif type(value) == "table" and value.Key ~= nil then
			payload[flag] = { Key = tostring(value.Key), Mode = value.Mode or "Toggle" }
		else
			payload[flag] = value
		end
	end
	return HttpService:JSONEncode(payload)
end

function Vertex:LoadConfig(jsonString)
	local ok, data = pcall(function()
		return HttpService:JSONDecode(jsonString)
	end)
	if not ok or type(data) ~= "table" then
		return false, data
	end

	self.ConfigState.Loading = true
	self.ConfigState.PendingConfig = {}

	for flag, value in pairs(data) do
		local setter = self.SetFlags[flag]
		if type(value) == "table" and value.Color then
			local hex = tostring(value.Color)
			value = {
				Color = hexToColor(hex),
				Alpha = value.Alpha or 1,
				HexValue = hex:gsub("#", ""),
			}
		elseif type(value) == "table" and value.Key then
			value = {
				Key = tostring(value.Key):gsub("^Enum%.KeyCode%.", ""),
				Mode = value.Mode or "Toggle",
			}
		end
		if setter then
			safeCall(setter, value)
		else
			self.ConfigState.PendingConfig[flag] = value
			self.Flags[flag] = value
		end
	end

	if type(self.ConfigState.PendingConfig) == "table" and next(self.ConfigState.PendingConfig) == nil then
		self.ConfigState.PendingConfig = nil
	end

	self.ConfigState.Loading = false
	return true, data
end

function Vertex:SaveConfigFile(configName)
	local path = self:GetConfigPath(configName or self.ConfigState.Name)
	if not path then
		return false, "Missing config name"
	end
	if type(writefile) ~= "function" then
		return false, "writefile unavailable"
	end

	ensureConfigFolders()
	local config = self:GetConfig()
	if not config then
		return false, "Failed to serialize config"
	end

	local success, result = pcall(writefile, path, config)
	if not success then
		return false, result
	end
	return true
end

function Vertex:LoadConfigFile(configName)
	local name = tostring(configName or "")
	if name == "" then
		return false, "Missing config name"
	end
	local path = self:GetConfigPath(name)
	if not path then
		return false, "Missing config name"
	end
	if type(isfile) ~= "function" or type(readfile) ~= "function" then
		return false, "filesystem unavailable"
	end

	local contents
	local migratedFromFlat = false
	if isfile(path) then
		local ok, result = pcall(readfile, path)
		if not ok then
			return false, result
		end
		contents = result
	else
		-- Migrate older flat workspace saves (e.g. tvlGuiByAva.json).
		local flatName = name
		if flatName:sub(-5) ~= ".json" then
			flatName = flatName .. ".json"
		end
		if isfile(flatName) then
			local ok, result = pcall(readfile, flatName)
			if not ok then
				return false, result
			end
			contents = result
			migratedFromFlat = true
		else
			return false, "Config file not found"
		end
	end

	local success, result = self:LoadConfig(contents)
	if success and migratedFromFlat then
		pcall(function()
			self:SaveConfigFile(name)
		end)
	end
	return success, result
end

function Vertex:LoadConfiguration(configName)
	local name = tostring(configName or self.ConfigState.Name or "")
	if configName ~= nil and name ~= "" then
		self.ConfigState.Name = name
	end
	if name == "" then
		return false, "Missing config name"
	end

	local success, result = self:LoadConfigFile(name)
	if self.ConfigState.AutoSave and tostring(self.ConfigState.Name or "") ~= "" then
		if not success then
			pcall(function()
				self:SaveConfigFile(self.ConfigState.Name)
			end)
		end
		self.ConfigState.AutoSaveReady = true
	end
	return success, result
end

function Vertex:SaveConfiguration(configName)
	return self:SaveConfigFile(configName or self.ConfigState.Name)
end

function Vertex:QueueConfigSave()
	local state = self.ConfigState
	if not state.AutoSave or not state.AutoSaveReady or state.Loading then
		return
	end
	if tostring(state.Name or "") == "" then
		return
	end

	state.SaveToken = (state.SaveToken or 0) + 1
	local token = state.SaveToken
	task.delay(state.SaveDelay or 0.25, function()
		if state.Loading or not state.AutoSave or not state.AutoSaveReady then
			return
		end
		if state.SaveToken ~= token then
			return
		end
		self:SaveConfigFile(state.Name)
	end)
end

function Vertex:ChangeTheme(themeName, color)
	if self.Theme[themeName] ~= nil and typeof(color) == "Color3" then
		self.Theme[themeName] = color
		if themeName == "Accent" then
			self.Theme.AccentHover = color:Lerp(Color3.new(1, 1, 1), 0.18)
			self.Theme.AccentText = color:Lerp(Color3.new(1, 1, 1), 0.35)
		end
		applyTheme()
	end
end

--=====================================================================
-- Public: teardown / aliases
--=====================================================================

-- Track a signal connection so Unload/Destroy can disconnect it.
function Vertex:Connect(signal, callback)
	local connection = signal:Connect(callback)
	table.insert(self.Connections, connection)
	return connection
end

function Vertex:DisconnectConnections()
	for _, connection in ipairs(self.Connections) do
		pcall(function()
			if typeof(connection) == "RBXScriptConnection" and connection.Connected then
				connection:Disconnect()
			elseif typeof(connection) == "RBXScriptConnection" then
				connection:Disconnect()
			end
		end)
	end
	table.clear(self.Connections)
end

function Vertex:Destroy()
	clearTooltips()
	self:DisconnectConnections()
	for _, window in ipairs(self.Windows) do
		if window.ReopenGui then
			pcall(function()
				window.ReopenGui:Destroy()
			end)
		end
		if window.ScreenGui then
			window.ScreenGui:Destroy()
		end
	end
	if self._notifyGui then
		self._notifyGui:Destroy()
		self._notifyGui = nil
	end
	for _, watermark in ipairs(self.Watermarks) do
		if watermark._conn then
			watermark._conn:Disconnect()
			watermark._conn = nil
		end
		if watermark.Instance then
			watermark.Instance:Destroy()
		end
	end
	if self._watermarkGui then
		self._watermarkGui:Destroy()
		self._watermarkGui = nil
	end
	if self._keybindListGui then
		self._keybindListGui:Destroy()
		self._keybindListGui = nil
	end
	table.clear(Motion)
	table.clear(self.Windows)
	table.clear(self.Watermarks)
	table.clear(self.KeybindLists)
	self.KeyList = nil
	table.clear(self.ActiveTooltips)
	table.clear(self.ThemeListeners)
	table.clear(self._flagData)
	table.clear(self.SetFlags)
end

function Vertex:Unload()
	if
		self.ConfigState
		and self.ConfigState.AutoSave
		and self.ConfigState.AutoSaveReady
		and tostring(self.ConfigState.Name or "") ~= ""
	then
		pcall(function()
			self:SaveConfigFile(self.ConfigState.Name)
		end)
	end
	self.ConfigState.AutoSaveReady = false

	-- Fade keybind lists out with unload.
	local fading = false
	for _, keyList in ipairs(self.KeybindLists) do
		if keyList and keyList.Instance and keyList.Instance.Visible then
			fading = true
			if keyList.FadeOut then
				keyList:FadeOut(16)
			else
				fadeOutTree(keyList.Instance, 16)
			end
		end
	end
	if fading then
		task.wait(0.28)
	end

	self:Destroy()
end

function Vertex:Exit()
	self:Unload()
end

-- Nexonix-style top-level aliases (old Vertex names still work).
function Vertex:Window(params)
	return self:CreateWindow(params)
end

return Vertex
