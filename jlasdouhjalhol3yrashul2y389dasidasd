			if window.CurrentTab ~= tab then
				motion(tabButton, "BackgroundTransparency", 0.45, 20)
			end
		end)
		connect(tabButton.MouseLeave, function()
			if window.CurrentTab ~= tab then
				motion(tabButton, "BackgroundTransparency", 1, 20)
			end
