			function section:AddSlider(sliderOptions)
				sliderOptions = sliderOptions or {}
				local minimum = tonumber(sliderOptions.Min) or 0
				local maximum = tonumber(sliderOptions.Max) or 100
				local decimals = tonumber(sliderOptions.Decimals)
				local step = tonumber(sliderOptions.Step) or (decimals and (10 ^ -decimals) or 1)
				local flag = sliderOptions.Flag or sliderOptions.Name or HttpService:GenerateGUID(false)
				local value = math.clamp(tonumber(sliderOptions.Default) or minimum, minimum, maximum)
				Vertex.Flags[flag] = value

				local row = makeControl(self, 68)
				local label = stackLabel(row, sliderOptions.Name or "Slider")
				attachTooltip(row, sliderOptions.Tooltip)
				local valueLabel = create(
					"TextLabel",
					merge(textProps(TEXT.Body, Vertex.Theme.AccentText, Vertex.Fonts.Bold), {
						Text = tostring(value) .. (sliderOptions.Suffix or ""),
						TextXAlignment = Enum.TextXAlignment.Right,
						AnchorPoint = Vector2.new(1, 0),
						Position = UDim2.new(1, -14, 0, 12),
						Size = UDim2.fromOffset(100, 18),
						ZIndex = 3,
					}),
					row
				)
				local track = create("TextButton", {
					Position = UDim2.new(0, 14, 0, 46),
					Size = UDim2.new(1, -28, 0, 7),
					BackgroundColor3 = Vertex.Theme.SurfaceHover,
					BorderSizePixel = 0,
					Text = "",
					AutoButtonColor = false,
					ZIndex = 3,
				}, row)
				addCorner(track, RADIUS.Pill)
				local fill = create("Frame", {
					Size = UDim2.fromScale((value - minimum) / math.max(maximum - minimum, 1), 1),
					BackgroundColor3 = Vertex.Theme.Accent,
					BorderSizePixel = 0,
					ZIndex = 4,
				}, track)
				addCorner(fill, RADIUS.Pill)

				local control = attachControlApi({ Instance = row, Label = label, Flag = flag, Value = value }, label)
				watchTheme(function()
					if not fill.Parent then
						return false
					end
					motion(fill, "BackgroundColor3", Vertex.Theme.Accent, 18)
					motion(valueLabel, "TextColor3", Vertex.Theme.AccentText, 18)
				end)
				function control:Set(newValue, silent)
					newValue = math.clamp(tonumber(newValue) or minimum, minimum, maximum)
					newValue = math.floor((newValue / step) + 0.5) * step
					if decimals then
						local scale = 10 ^ decimals
						newValue = math.floor(newValue * scale + 0.5) / scale
					end
					self.Value = newValue
					Vertex.Flags[flag] = newValue
					valueLabel.Text = tostring(newValue) .. (sliderOptions.Suffix or "")
					motion(fill, "Size", UDim2.fromScale((newValue - minimum) / math.max(maximum - minimum, 1), 1), 26)
					if not silent then
						safeCall(sliderOptions.Callback, newValue)
					end
				end

				local sliding = false
				local function update(input)
					local percent = math.clamp(
						(input.Position.X - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X, 1),
						0,
						1
					)
					control:Set(minimum + ((maximum - minimum) * percent))
				end
				connect(track.InputBegan, function(input)
					if
						input.UserInputType == Enum.UserInputType.MouseButton1
						or input.UserInputType == Enum.UserInputType.Touch
					then
						sliding = true
						update(input)
					end
				end)
				connect(UserInputService.InputChanged, function(input)
					if
						sliding
						and (
							input.UserInputType == Enum.UserInputType.MouseMovement
							or input.UserInputType == Enum.UserInputType.Touch
						)
					then
						update(input)
					end
				end)
				connect(UserInputService.InputEnded, function(input)
					if
						input.UserInputType == Enum.UserInputType.MouseButton1
						or input.UserInputType == Enum.UserInputType.Touch
					then
						sliding = false
					end
				end)
				registerFlag(flag, function(v)
					control:Set(v, false)
				end)
				table.insert(self.Items, control)
				return control
			end

			function section:AddRangeSlider(rangeOptions)
				rangeOptions = rangeOptions or {}
				local minimum = tonumber(rangeOptions.Min) or 0
				local maximum = tonumber(rangeOptions.Max) or 100
				local gap = tonumber(rangeOptions.Gap) or 1
				local step = tonumber(rangeOptions.Step) or 1
				local flag = rangeOptions.Flag or rangeOptions.Name or HttpService:GenerateGUID(false)
				local defaults = rangeOptions.Default or { minimum, maximum }
				local low = math.clamp(tonumber(defaults[1] or defaults.min) or minimum, minimum, maximum)
				local high = math.clamp(tonumber(defaults[2] or defaults.max) or maximum, minimum, maximum)
				if high - low < gap then
					high = math.min(maximum, low + gap)
				end
				Vertex.Flags[flag] = { low, high }

				local row = makeControl(self, 68)
				local label = stackLabel(row, rangeOptions.Name or "Range")
				attachTooltip(row, rangeOptions.Tooltip)
				local valueLabel = create(
					"TextLabel",
					merge(textProps(TEXT.Body, Vertex.Theme.AccentText, Vertex.Fonts.Bold), {
						Text = tostring(low) .. " – " .. tostring(high) .. (rangeOptions.Suffix or ""),
						TextXAlignment = Enum.TextXAlignment.Right,
						AnchorPoint = Vector2.new(1, 0),
						Position = UDim2.new(1, -14, 0, 12),
						Size = UDim2.fromOffset(140, 18),
						ZIndex = 3,
					}),
					row
				)
				local track = create("TextButton", {
					Position = UDim2.new(0, 14, 0, 46),
					Size = UDim2.new(1, -28, 0, 7),
					BackgroundColor3 = Vertex.Theme.SurfaceHover,
					BorderSizePixel = 0,
					Text = "",
					AutoButtonColor = false,
					ZIndex = 3,
				}, row)
				addCorner(track, RADIUS.Pill)
				local fill = create("Frame", {
					BackgroundColor3 = Vertex.Theme.Accent,
					BorderSizePixel = 0,
					ZIndex = 4,
				}, track)
				addCorner(fill, RADIUS.Pill)
				watchTheme(function()
					if not fill.Parent then
						return false
					end
					motion(fill, "BackgroundColor3", Vertex.Theme.Accent, 18)
					motion(valueLabel, "TextColor3", Vertex.Theme.AccentText, 18)
				end)
				local function makeHandle(xScale)
					local handle = create("Frame", {
						AnchorPoint = Vector2.new(0.5, 0.5),
						Position = UDim2.fromScale(xScale, 0.5),
						Size = UDim2.fromOffset(14, 14),
						BackgroundColor3 = Vertex.Theme.Knob,
						BorderSizePixel = 0,
						ZIndex = 5,
					}, track)
					addCorner(handle, RADIUS.Pill)
					return handle
				end
				local lowHandle = makeHandle((low - minimum) / math.max(maximum - minimum, 1))
				local highHandle = makeHandle((high - minimum) / math.max(maximum - minimum, 1))

				local control = attachControlApi({
					Instance = row,
					Label = label,
					Flag = flag,
					Value = { low, high },
				}, label)
				local function layout()
					local span = math.max(maximum - minimum, 1)
					local lowP = (low - minimum) / span
					local highP = (high - minimum) / span
					fill.Position = UDim2.fromScale(lowP, 0)
					fill.Size = UDim2.fromScale(math.max(highP - lowP, 0), 1)
					lowHandle.Position = UDim2.fromScale(lowP, 0.5)
					highHandle.Position = UDim2.fromScale(highP, 0.5)
					valueLabel.Text = tostring(low) .. " – " .. tostring(high) .. (rangeOptions.Suffix or "")
				end
				function control:Set(minValue, maxValue, silent)
					if type(minValue) == "table" then
						maxValue = minValue[2] or minValue.max
						minValue = minValue[1] or minValue.min
					end
					low = math.clamp(tonumber(minValue) or low, minimum, maximum)
					high = math.clamp(tonumber(maxValue) or high, minimum, maximum)
					if high - low < gap then
						high = math.min(maximum, low + gap)
					end
					low = math.floor((low / step) + 0.5) * step
					high = math.floor((high / step) + 0.5) * step
					self.Value = { low, high }
					Vertex.Flags[flag] = self.Value
					layout()
					if not silent then
						safeCall(rangeOptions.Callback, low, high)
					end
				end
				layout()

				local dragging = nil
				local function update(input)
					local percent = math.clamp(
						(input.Position.X - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X, 1),
						0,
						1
					)
					local value = minimum + ((maximum - minimum) * percent)
					if dragging == "low" then
						control:Set(math.min(value, high - gap), high)
					else
						control:Set(low, math.max(value, low + gap))
					end
				end
				local function beginDrag(handle, which)
					connect(handle.InputBegan, function(input)
						if input.UserInputType == Enum.UserInputType.MouseButton1 then
							dragging = which
							update(input)
						end
					end)
				end
				beginDrag(lowHandle, "low")
				beginDrag(highHandle, "high")
				connect(track.InputBegan, function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						local percent = (input.Position.X - track.AbsolutePosition.X)
							/ math.max(track.AbsoluteSize.X, 1)
						local value = minimum + ((maximum - minimum) * percent)
						dragging = math.abs(value - low) <= math.abs(value - high) and "low" or "high"
						update(input)
					end
				end)
				connect(UserInputService.InputChanged, function(input)
					if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
						update(input)
					end
				end)
				connect(UserInputService.InputEnded, function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						dragging = nil
					end
				end)
				registerFlag(flag, function(v)
					control:Set(v, nil, false)
				end)
				table.insert(self.Items, control)
				return control
			end

