	function window:SetVisible(value)
		value = value == true
		if self._closing or value == self.Visible then
			return
		end

		local settled = not self._visAnimating
		self._visAnimating = true
		self.Visible = value
		self._visGen = (self._visGen or 0) + 1
		local gen = self._visGen

		if value then
			setReopenChipVisible(false)
			screenGui.Enabled = true

			-- First open captures construction opacities; later opens reuse the
			-- last settled snapshot (refreshed below once fully shown).
			if not self._restAlpha then
				self._restAlpha = snapshotAlpha(main)
			end
			local alpha = self._restAlpha
			local rest = self._restPosition or main.Position

			setNow(uiScale, "Scale", 0.9)
			setNow(main, "Position", rest - UDim2.fromOffset(0, 22))
			setAlpha(alpha, false)

			motion(uiScale, "Scale", 1, 13)
			motion(main, "Position", rest, 15)
			fadeAlpha(alpha, true, 14)

			task.delay(0.34, function()
				if self.Visible and gen == self._visGen then
					self._visAnimating = false
					-- Include tabs/controls that were added after the first open.
					self._restAlpha = snapshotAlpha(main)
					self._restPosition = main.Position
				end
			end)
		else
			clearTooltips()
			setReopenChipVisible(false)

			-- When settled, refresh so every live control is in the restore list.
			if settled or not self._restAlpha then
				self._restAlpha = snapshotAlpha(main)
			end

			local rest = main.Position
			if self._restPosition and (main.Position.Y.Offset - self._restPosition.Y.Offset) > 10 then
				rest = self._restPosition
			else
				self._restPosition = rest
			end

			motion(uiScale, "Scale", 0.9, 19)
			motion(main, "Position", rest + UDim2.fromOffset(0, 22), 19)
			-- Fade the whole live tree, not a stale first-open snapshot.
			fadeOutTree(main, 20)

			task.delay(0.34, function()
				if not self.Visible and gen == self._visGen then
					screenGui.Enabled = false
					setNow(uiScale, "Scale", 1)
					setNow(main, "Position", rest)
					self._visAnimating = false
					setReopenChipVisible(true)
				end
			end)
		end
	end

