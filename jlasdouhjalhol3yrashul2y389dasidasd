			-- Nested color swatch + HSV popover attached to a control row.
			local function attachColorPicker(control, data)
				data = data or {}
				local flag = data.Flag or HttpService:GenerateGUID(false)
				local color = data.Default or Vertex.Theme.Accent
				local alpha = tonumber(data.Alpha) or 1
				local rightPad = control._nestOffset or 14
				control._nestOffset = rightPad + 30
				control.Instance.ClipsDescendants = false

				local function screenGuiOf(instance)
					local current = instance
					while current do
						if current:IsA("ScreenGui") then
							return current
						end
						current = current.Parent
					end
					return getGuiParent()
				end

				local swatch = create("TextButton", {
					Name = "ColorSwatch",
					AnchorPoint = Vector2.new(1, 0.5),
					Position = UDim2.new(1, -rightPad, 0.5, 0),
					Size = UDim2.fromOffset(22, 22),
					BackgroundColor3 = color,
					BorderSizePixel = 0,
					Text = "",
					AutoButtonColor = false,
					ZIndex = 5,
				}, control.Instance)
				addCorner(swatch, RADIUS.Inner)
				addStroke(swatch, FIELD_STROKE, nil, FIELD_STROKE_THICKNESS)

				-- Float on ScreenGui so the page ScrollingFrame doesn't clip it.
				local picker = create("Frame", {
					Name = "ColorPicker",
					Visible = false,
					BackgroundColor3 = Vertex.Theme.SurfaceRaised,
					BackgroundTransparency = 1,
					BorderSizePixel = 0,
					AnchorPoint = Vector2.new(1, 0),
					Size = UDim2.fromOffset(196, 150),
					ZIndex = 120,
				}, screenGuiOf(control.Instance))
				addCorner(picker, RADIUS.Card)
				local pickerShadow = addDropShadow(picker, {
					Blur = 52,
					YOffset = 12,
					Spread = 16,
					Transparency = 0.16,
				})
				local pickerShadowRest = 0.16
				addPadding(picker, 10, 10, 10, 10)
				local pickerScale = create("UIScale", { Scale = 0.94 }, picker)
				create("UIListLayout", {
					Padding = UDim.new(0, 10),
					SortOrder = Enum.SortOrder.LayoutOrder,
				}, picker)

				local function setPickerShadowAlpha(alpha, animate, speed)
					if not pickerShadow then
						return
					end
					if pickerShadow.ClassName == "UIShadow" then
						if animate then
							motion(pickerShadow, "Transparency", alpha, speed)
						else
							setNow(pickerShadow, "Transparency", alpha)
						end
					elseif pickerShadow:IsA("ImageLabel") then
						if animate then
							motion(pickerShadow, "ImageTransparency", alpha, speed)
						else
							setNow(pickerShadow, "ImageTransparency", alpha)
						end
					end
				end

				local hue, sat, val = Color3.toHSV(color)
				local satVal = create("ImageButton", {
					Name = "SatVal",
					BackgroundColor3 = Color3.fromHSV(hue, 1, 1),
					BackgroundTransparency = 1,
					BorderSizePixel = 0,
					Size = UDim2.new(1, 0, 0, 108),
					Image = "rbxassetid://4155801252",
					ImageTransparency = 1,
					AutoButtonColor = false,
					ClipsDescendants = false,
					ZIndex = 121,
					LayoutOrder = 1,
				}, picker)
				addCorner(satVal, RADIUS.Inner)

				-- SV picker ring — sits on the selected saturation/value.
				local svCursor = create("Frame", {
					Name = "SVCursor",
					AnchorPoint = Vector2.new(0.5, 0.5),
					Size = UDim2.fromOffset(14, 14),
					BackgroundColor3 = Color3.new(1, 1, 1),
					BackgroundTransparency = 1,
					BorderSizePixel = 0,
					ZIndex = 123,
				}, satVal)
				addCorner(svCursor, 100)
				local svCursorStroke = addStroke(svCursor, 1, Color3.new(1, 1, 1), 2)

				local hueBar = create("TextButton", {
					Name = "Hue",
					Size = UDim2.new(1, 0, 0, 12),
					BackgroundColor3 = Color3.new(1, 1, 1),
					BackgroundTransparency = 1,
					BorderSizePixel = 0,
					Text = "",
					AutoButtonColor = false,
					ClipsDescendants = false,
					ZIndex = 121,
					LayoutOrder = 2,
				}, picker)
				addCorner(hueBar, RADIUS.Pill)
				create("UIGradient", {
					Color = ColorSequence.new({
						ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
						ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
						ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
						ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
						ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 0, 255)),
						ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
						ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0)),
					}),
				}, hueBar)

				-- Hue marker — white circle that tracks hue along the bar.
				local hueCursor = create("Frame", {
					Name = "HueCursor",
					AnchorPoint = Vector2.new(0.5, 0.5),
					Position = UDim2.fromScale(0, 0.5),
					Size = UDim2.fromOffset(14, 14),
					BackgroundColor3 = Color3.new(1, 1, 1),
					BackgroundTransparency = 1,
					BorderSizePixel = 0,
					ZIndex = 123,
				}, hueBar)
				addCorner(hueCursor, 100)
				local hueCursorStroke = addStroke(hueCursor, 1, Color3.new(1, 1, 1), 2)

				local colorControl = {
					Instance = swatch,
					Flag = flag,
					Value = { Color = color, Alpha = alpha, HexValue = colorToHex(color), Transparency = 1 - alpha },
					Open = false,
				}

				local function placePicker()
					local gui = screenGuiOf(swatch)
					picker.Parent = gui
					-- Same as Toggle/Hold: AnchorPoint top-right, sit left of the cursor
					-- so the colour swatch stays visible under the mouse.
					local mouse = UserInputService:GetMouseLocation()
					local x = math.floor(mouse.X - 6)
					local y = math.floor(mouse.Y + 10)
					picker.Position = UDim2.fromOffset(math.max(8, x), math.max(8, y))
				end

				local function updateCursors(animate)
					local svPos = UDim2.new(sat, 0, 1 - val, 0)
					local huePos = UDim2.new(hue, 0, 0.5, 0)
					svCursor.BackgroundColor3 = color
					if animate then
						motion(svCursor, "Position", svPos, 22)
						motion(hueCursor, "Position", huePos, 22)
					else
						setNow(svCursor, "Position", svPos)
						setNow(hueCursor, "Position", huePos)
					end
				end

				local function pushValue(silent, animateCursor)
					colorControl.Value = {
						Color = color,
						Alpha = alpha,
						HexValue = colorToHex(color),
						Transparency = 1 - alpha,
					}
					Vertex.Flags[flag] = colorControl.Value
					swatch.BackgroundColor3 = color
					satVal.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
					updateCursors(animateCursor == true)
					if not silent then
						safeCall(data.Callback, colorControl.Value)
					end
				end
				function colorControl:Set(newColor, newAlpha, silent)
					if typeof(newColor) == "Color3" then
						color = newColor
						hue, sat, val = Color3.toHSV(color)
					elseif type(newColor) == "table" and typeof(newColor.Color) == "Color3" then
						color = newColor.Color
						alpha = tonumber(newColor.Alpha) or alpha
						hue, sat, val = Color3.toHSV(color)
					elseif type(newColor) == "string" then
						color = hexToColor(newColor)
						hue, sat, val = Color3.toHSV(color)
					end
					if newAlpha ~= nil then
						alpha = tonumber(newAlpha) or alpha
					end
					pushValue(silent, true)
				end
				function colorControl:SetOpen(open)
					open = open == true
					if open == self.Open then
						return
					end
					self.Open = open
					if open then
						placePicker()
						task.defer(placePicker)
						updateCursors(false)
						picker.Visible = true
						setNow(pickerScale, "Scale", 0.94)
						setNow(picker, "BackgroundTransparency", 1)
						setPickerShadowAlpha(1, false)
						setNow(satVal, "BackgroundTransparency", 1)
						setNow(satVal, "ImageTransparency", 1)
						setNow(hueBar, "BackgroundTransparency", 1)
						setNow(svCursor, "BackgroundTransparency", 1)
						setNow(svCursorStroke, "Transparency", 1)
						setNow(hueCursor, "BackgroundTransparency", 1)
						setNow(hueCursorStroke, "Transparency", 1)
						motion(pickerScale, "Scale", 1, 16)
						motion(picker, "BackgroundTransparency", 0, 16)
						setPickerShadowAlpha(pickerShadowRest, true, 16)
						motion(satVal, "BackgroundTransparency", 0, 16)
						motion(satVal, "ImageTransparency", 0, 16)
						motion(hueBar, "BackgroundTransparency", 0, 16)
						motion(svCursor, "BackgroundTransparency", 0, 16)
						motion(svCursorStroke, "Transparency", 0, 16)
						motion(hueCursor, "BackgroundTransparency", 0, 16)
						motion(hueCursorStroke, "Transparency", 0, 16)
					else
						motion(pickerScale, "Scale", 0.94, 20)
						motion(picker, "BackgroundTransparency", 1, 20)
						setPickerShadowAlpha(1, true, 20)
						motion(satVal, "BackgroundTransparency", 1, 20)
						motion(satVal, "ImageTransparency", 1, 20)
						motion(hueBar, "BackgroundTransparency", 1, 20)
						motion(svCursor, "BackgroundTransparency", 1, 20)
						motion(svCursorStroke, "Transparency", 1, 20)
						motion(hueCursor, "BackgroundTransparency", 1, 20)
						motion(hueCursorStroke, "Transparency", 1, 20)
						task.delay(0.18, function()
							if not colorControl.Open and picker.Parent then
								picker.Visible = false
							end
						end)
					end
				end
				function colorControl:SetVisibility(visible)
					swatch.Visible = visible == true
					if not visible then
						self:SetOpen(false)
					end
				end
				local function sampleSatVal(input)
					local relX = math.clamp(
						(input.Position.X - satVal.AbsolutePosition.X) / math.max(satVal.AbsoluteSize.X, 1),
						0,
						1
					)
					local relY = math.clamp(
						(input.Position.Y - satVal.AbsolutePosition.Y) / math.max(satVal.AbsoluteSize.Y, 1),
						0,
						1
					)
					sat, val = relX, 1 - relY
					color = Color3.fromHSV(hue, sat, val)
					pushValue(false, false)
				end
				local function sampleHue(input)
					hue = math.clamp(
						(input.Position.X - hueBar.AbsolutePosition.X) / math.max(hueBar.AbsoluteSize.X, 1),
						0,
						1
					)
					color = Color3.fromHSV(hue, sat, val)
					pushValue(false, false)
				end
				connect(swatch.MouseButton1Click, function()
					colorControl:SetOpen(not colorControl.Open)
				end)
				connect(satVal.InputBegan, function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						sampleSatVal(input)
					end
				end)
				connect(satVal.InputChanged, function(input)
					if
						input.UserInputType == Enum.UserInputType.MouseMovement
						and input.UserInputState == Enum.UserInputState.Change
					then
						if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
							sampleSatVal(input)
						end
					end
				end)
				connect(hueBar.InputBegan, function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						sampleHue(input)
					end
				end)
				connect(hueBar.InputChanged, function(input)
					if input.UserInputType == Enum.UserInputType.MouseMovement then
						if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
							sampleHue(input)
						end
					end
				end)
				-- Close when clicking elsewhere.
				connect(UserInputService.InputBegan, function(input)
					if not colorControl.Open then
						return
					end
					if
						input.UserInputType ~= Enum.UserInputType.MouseButton1
						and input.UserInputType ~= Enum.UserInputType.Touch
					then
						return
					end
					task.defer(function()
						if not colorControl.Open then
							return
						end
						local pos = input.Position
						local pPos, pSize = picker.AbsolutePosition, picker.AbsoluteSize
						local sPos, sSize = swatch.AbsolutePosition, swatch.AbsoluteSize
						local overPicker = pos.X >= pPos.X
							and pos.X <= pPos.X + pSize.X
							and pos.Y >= pPos.Y
							and pos.Y <= pPos.Y + pSize.Y
						local overSwatch = pos.X >= sPos.X
							and pos.X <= sPos.X + sSize.X
							and pos.Y >= sPos.Y
							and pos.Y <= sPos.Y + sSize.Y
						if not overPicker and not overSwatch then
							colorControl:SetOpen(false)
						end
					end)
				end)
				connect(swatch.AncestryChanged, function(_, parentNow)
					if not parentNow and picker.Parent then
						picker:Destroy()
					end
				end)
				registerFlag(flag, function(v)
					colorControl:Set(v, nil, false)
				end)
				pushValue(true, false)
				return colorControl
			end

			-- Nested keybind pill attached to a control row.
			-- Toggleable = true → Hold/Toggle gear; otherwise one-shot (no settings).
			local function attachNestedKeybind(control, data)
				data = data or {}
				local flag = data.Flag or data.Name or HttpService:GenerateGUID(false)
				local value = data.Default or Enum.KeyCode.Unknown
				local toggleable = data.Toggleable == true
				local rightPad = control._nestOffset or 14
				-- Bind pill (+ optional settings gear with 12px gap).
				control._nestOffset = rightPad + (toggleable and 110 or 78)
				control.Instance.ClipsDescendants = false

				local settingsPad = rightPad
				local bindPad = toggleable and (rightPad + 40) or rightPad

				local bindButton = create(
					"TextButton",
					merge(textProps(TEXT.Micro, Vertex.Theme.TextMuted, Vertex.Fonts.Bold), {
						AnchorPoint = Vector2.new(1, 0.5),
						Position = UDim2.new(1, -bindPad, 0.5, 0),
						Size = UDim2.fromOffset(70, 24),
						BackgroundColor3 = Vertex.Theme.Background,
						BorderSizePixel = 0,
						Text = value.Name,
						TextXAlignment = Enum.TextXAlignment.Center,
						AutoButtonColor = false,
						ZIndex = 5,
					}),
					control.Instance
				)
				addCorner(bindButton, RADIUS.Inner)
				addStroke(bindButton, FIELD_STROKE, nil, FIELD_STROKE_THICKNESS)

				local keyControl = {
					Instance = bindButton,
					Flag = flag,
					Value = value,
					Toggleable = toggleable,
					Mode = toggleable and normalizeKeyMode(data.Mode) or "Press",
					_listening = false,
				}
				function keyControl:Set(newValue, silent)
					local modeFromTable
					if typeof(newValue) == "table" and newValue.Key then
						modeFromTable = newValue.Mode
						newValue = resolveKeyCode(newValue.Key)
					end
					if typeof(newValue) ~= "EnumItem" then
						return
					end
					self.Value = newValue
					if self.Toggleable and modeFromTable then
						self.Mode = normalizeKeyMode(modeFromTable)
					end
					Vertex.Flags[flag] = { Key = newValue.Name, Mode = self.Mode }
					bindButton.Text = newValue.Name
					if not silent then
						safeCall(data.Callback, newValue)
					end
				end
				function keyControl:SetMode(mode)
					if not self.Toggleable then
						return
					end
					self.Mode = normalizeKeyMode(mode)
					Vertex.Flags[flag] = { Key = self.Value.Name, Mode = self.Mode }
					if self.Active and self.Mode == "Hold" then
						self:SetActive(false)
					end
				end

				local settingsBtn
				if toggleable then
					settingsBtn = attachKeybindModeSettings(control.Instance, keyControl, settingsPad)
				end
				function keyControl:SetVisibility(visible)
					visible = visible == true
					bindButton.Visible = visible
					if settingsBtn then
						settingsBtn.Visible = visible
					end
				end
				wireKeybindRuntime(keyControl, data)
				linkKeybindToList(keyControl, data, (control.Label and control.Label.Text) or data.Name or flag)

				connect(bindButton.MouseButton1Click, function()
					keyControl._listening = true
					bindButton.Text = "..."
					bindButton.TextColor3 = Vertex.Theme.AccentText
				end)
				connect(UserInputService.InputBegan, function(input)
					if keyControl._listening and input.KeyCode ~= Enum.KeyCode.Unknown then
						keyControl._listening = false
						bindButton.TextColor3 = Vertex.Theme.TextMuted
						keyControl:Set(input.KeyCode)
					end
				end)
				registerFlag(flag, function(v)
					keyControl:Set(v, false)
				end)
				keyControl:Set(value, true)
				return keyControl
			end

			function section:AddLabel(labelOptions)
				if type(labelOptions) == "string" then
					labelOptions = { Text = labelOptions }
				end
				labelOptions = labelOptions or {}
				local row = makeControl(self, labelOptions.Description and 56 or 42)
				local label =
					inlineLabel(row, labelOptions.Text or labelOptions.Name or "Label", labelOptions.Description)
				attachTooltip(row, labelOptions.Tooltip)
				local control = attachControlApi({ Instance = row, Label = label, _nestOffset = 14 }, label)
				function control:Set(text)
					label.Text = tostring(text)
				end
				function control:ColorPicker(data)
					return attachColorPicker(self, data)
				end
				function control:Keybind(data)
					return attachNestedKeybind(self, data)
				end
				table.insert(self.Items, control)
				return control
			end

			function section:AddButton(buttonOptions)
				buttonOptions = buttonOptions or {}
				local row = makeControl(self, buttonOptions.Description and 56 or SPACING.ControlH)
				local button = create("TextButton", {
					BackgroundTransparency = 1,
					BorderSizePixel = 0,
					Size = UDim2.fromScale(1, 1),
					Text = "",
					AutoButtonColor = false,
					ZIndex = 3,
				}, row)
				local label = inlineLabel(button, buttonOptions.Name or "Button", buttonOptions.Description)
				attachTooltip(row, buttonOptions.Tooltip)
				local arrow = makeGlyph(button, "chevron-right", "›", 18, Vertex.Theme.TextDim)
				arrow.AnchorPoint = Vector2.new(1, 0.5)
				arrow.Position = UDim2.new(1, -12, 0.5, 0)
				hoverFill(button, Vertex.Theme.SurfaceRaised, Vertex.Theme.SurfaceHover, row)
				local control = attachControlApi({
					Instance = row,
					Label = label,
					Press = function()
						safeCall(buttonOptions.Callback)
