		end

		local cancelBtn = makeAction("Cancel", 1, Vertex.Theme.SurfaceHover, Vertex.Theme.Text)
		local unloadBtn = makeAction("Unload", 2, Vertex.Theme.Danger, Vertex.Theme.Text)

		local function dismiss()
			if not confirmOpen then
				return
			end
			confirmOpen = false
			motion(overlay, "BackgroundTransparency", 1, 20)
			motion(card, "BackgroundTransparency", 1, 20)
			setCardShadowAlpha(1, true, 20)
			motion(cardScale, "Scale", 0.94, 20)
			motion(title, "TextTransparency", 1, 20)
			motion(body, "TextTransparency", 1, 20)
			motion(cancelBtn, "BackgroundTransparency", 1, 20)
			motion(cancelBtn, "TextTransparency", 1, 20)
			motion(unloadBtn, "BackgroundTransparency", 1, 20)
			motion(unloadBtn, "TextTransparency", 1, 20)
			task.delay(0.2, function()
				if overlay.Parent then
					overlay:Destroy()
				end
			end)
		end

		connect(cancelBtn.MouseButton1Click, dismiss)
		connect(overlay.InputBegan, function(input)
			if
				input.UserInputType == Enum.UserInputType.MouseButton1
				or input.UserInputType == Enum.UserInputType.Touch
			then
				-- Only dismiss when clicking the dim area, not the card.
				local pos = input.Position
				local cPos, cSize = card.AbsolutePosition, card.AbsoluteSize
				local overCard = pos.X >= cPos.X
					and pos.X <= cPos.X + cSize.X
					and pos.Y >= cPos.Y
					and pos.Y <= cPos.Y + cSize.Y
				if not overCard then
					dismiss()
				end
			end
		end)
		connect(unloadBtn.MouseButton1Click, function()
			confirmOpen = false
			if overlay.Parent then
				overlay:Destroy()
			end
