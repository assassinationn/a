		motion(body, "TextTransparency", 0, 16)
		motion(cancelBtn, "BackgroundTransparency", 0, 16)
		motion(cancelBtn, "TextTransparency", 0, 16)
		motion(unloadBtn, "BackgroundTransparency", 0, 16)
		motion(unloadBtn, "TextTransparency", 0, 16)
	end

